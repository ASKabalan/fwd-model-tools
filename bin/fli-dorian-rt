#!/usr/bin/env python
"""fli-dorian-rt: CPU-only MPI ray-tracing entry point.

Runs dorian ray-tracing via MPI. No JAX distributed init — dorian handles
its own parallelism through MPI.
"""
import os

os.environ["JAX_PLATFORM_NAME"] = "cpu"
os.environ["JAX_PLATFORMS"] = "cpu"

from mpi4py import MPI

comm = MPI.COMM_WORLD
rank = comm.Get_rank()
size = comm.Get_size()
print(f"MPI rank={rank}, size={size}")

from jax_fli.scripts.fli_dorian_rt import main

if __name__ == "__main__":
    main()
